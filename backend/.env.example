# DevMind backend local environment example.
# Copy values into your IDE Run Configuration or your local shell.
# Do not commit real passwords or API keys.
# Docker Compose exposes MySQL on localhost:3307 and Redis on localhost:6380.
# When using Compose, update DEVMIND_DB_URL to port 3307 and DEVMIND_REDIS_PORT to 6380.

DEVMIND_DB_URL=jdbc:mysql://localhost:3306/devmind?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DEVMIND_DB_USERNAME=root
DEVMIND_DB_PASSWORD=change-me
DEVMIND_FLYWAY_ENABLED=true

DEVMIND_REDIS_HOST=localhost
DEVMIND_REDIS_PORT=6379
DEVMIND_REDIS_DATABASE=1
DEVMIND_REDIS_PASSWORD=

DEVMIND_JWT_SECRET=change-me-to-a-long-random-local-secret
DEVMIND_TOKEN_EXPIRE_SECONDS=7200
DEVMIND_BLACKLIST_FAIL_OPEN=true

DEVMIND_AI_ASK_RATE_LIMIT_ENABLED=true
DEVMIND_AI_ASK_RATE_LIMIT_PER_MINUTE=10
DEVMIND_AI_ASK_RATE_LIMIT_FAIL_OPEN=true

DEVMIND_RETRIEVAL_TECH_PHRASES_ENABLED=true

DEVMIND_VECTOR_STORE_PROVIDER=mysql-json
DEVMIND_PGVECTOR_URL=jdbc:postgresql://localhost:5433/devmind_vectors
DEVMIND_PGVECTOR_USERNAME=devmind
DEVMIND_PGVECTOR_PASSWORD=devmind
DEVMIND_PGVECTOR_DIMENSION=1024

DEVMIND_AI_PROVIDER=mock
DEVMIND_DEEPSEEK_API_KEY=
DEVMIND_DEEPSEEK_BASE_URL=https://api.deepseek.com
DEVMIND_DEEPSEEK_MODEL=deepseek-v4-flash
DEVMIND_DEEPSEEK_TEMPERATURE=0.2

DEVMIND_AI_EMBEDDING_PROVIDER=local-sparse-vector
DEVMIND_AI_EMBEDDING_REMOTE_BASE_URL=
DEVMIND_AI_EMBEDDING_REMOTE_API_KEY=
DEVMIND_AI_EMBEDDING_REMOTE_MODEL=
# Set both remote and pgvector dimensions to 1024 when enabling remote-dense + pgvector.
DEVMIND_AI_EMBEDDING_REMOTE_DIMENSION=0

DEVMIND_AI_RERANK_PROVIDER=none
DEVMIND_AI_RERANK_REMOTE_BASE_URL=
DEVMIND_AI_RERANK_REMOTE_API_KEY=
DEVMIND_AI_RERANK_REMOTE_MODEL=
