@baseUrl = http://localhost:8081
@username = testuser
@password = 123456

### Register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}",
  "nickname": "Test User",
  "email": "testuser@example.com"
}

### Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {% client.global.set("authToken", response.body.data.token); %}

### Current User
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{authToken}}

### Create Knowledge Document
POST {{baseUrl}}/api/v1/documents
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Redis cache penetration review",
  "content": "Problem:\nThe API may hit the database repeatedly when a missing key is requested many times.\n\nRoot cause:\nThe system only caches existing data, so non-existing data bypasses Redis every time.\n\nSolution:\nCache empty values for a short TTL, validate illegal parameters early, and add rate limiting for abnormal traffic.\n\nInterview talking point:\nCache penetration is different from cache breakdown and cache avalanche. The key is to protect the database from repeated misses.",
  "sourceType": "bug_review",
  "tags": "redis,cache,backend",
  "summary": "A short review note about cache penetration."
}

> {% client.global.set("documentId", response.body.data.id); %}

### Import Knowledge Document From Markdown
POST {{baseUrl}}/api/v1/documents/import
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=devmindBoundary

--devmindBoundary
Content-Disposition: form-data; name="file"; filename="redis-cache-penetration.md"
Content-Type: text/markdown

< ./../samples/redis-cache-penetration.md
--devmindBoundary
Content-Disposition: form-data; name="sourceType"

imported_note
--devmindBoundary
Content-Disposition: form-data; name="tags"

redis,cache,imported
--devmindBoundary--

> {% client.global.set("documentId", response.body.data.id); %}

### List Documents
GET {{baseUrl}}/api/v1/documents?pageNo=1&pageSize=10
Authorization: Bearer {{authToken}}

### Search Documents
GET {{baseUrl}}/api/v1/documents?keyword=Redis&pageNo=1&pageSize=10
Authorization: Bearer {{authToken}}

### Get Document Detail
GET {{baseUrl}}/api/v1/documents/{{documentId}}
Authorization: Bearer {{authToken}}

### List Document Chunks
GET {{baseUrl}}/api/v1/documents/{{documentId}}/chunks
Authorization: Bearer {{authToken}}

### Search Chunks
GET {{baseUrl}}/api/v1/search/chunks?keyword=Redis&limit=5
Authorization: Bearer {{authToken}}

### Restore Chunks By Ask Log Chunk IDs
# Use retrieved_chunk_ids and retrieval_keyword from ai_ask_log.
# The optional keywords parameter recalculates the same explainable retrieval score.
GET {{baseUrl}}/api/v1/search/chunks/by-ids?ids=1,2,3&keywords=Redis,cache,penetration
Authorization: Bearer {{authToken}}

### Ask AI
POST {{baseUrl}}/api/v1/ai/ask
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "question": "面试中应该如何解释 Redis 缓存穿透？",
  "retrievalLimit": 3
}

> {% client.global.set("askLogId", response.body.data.logId); %}

### Ask AI With No Retrieved Context
# Expected: the backend returns a deterministic fallback answer and does not call the LLM provider.
POST {{baseUrl}}/api/v1/ai/ask
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "question": "Kubernetes Pod 驱逐策略是什么？",
  "retrievalLimit": 3
}

### Ask AI Failure Log Demo
# To test failure logging:
# 1. Set DEVMIND_AI_PROVIDER=unknown in the backend run configuration.
# 2. Restart the backend.
# 3. Run this request after creating the Redis cache penetration document.
# Expected: the API returns an error response, and ai_ask_log gets status = 0.
POST {{baseUrl}}/api/v1/ai/ask
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "question": "面试中应该如何解释 Redis 缓存穿透？",
  "retrievalLimit": 3
}

### List AI Ask Logs
GET {{baseUrl}}/api/v1/ai/ask-logs?pageNo=1&pageSize=10
Authorization: Bearer {{authToken}}

### Submit AI Ask Feedback
POST {{baseUrl}}/api/v1/ai/ask-logs/{{askLogId}}/feedback
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "helpful": false,
  "reason": "回答基本正确，但没有清楚对比缓存穿透、缓存击穿和缓存雪崩。",
  "expectedAnswer": "说明缓存空值、参数校验、布隆过滤器或限流，并解释它和缓存击穿、缓存雪崩的区别。"
}

### List Bad Case Feedback
GET {{baseUrl}}/api/v1/ai/ask-feedback?helpful=false&pageNo=1&pageSize=10
Authorization: Bearer {{authToken}}

### List Feedback For One Ask Log
GET {{baseUrl}}/api/v1/ai/ask-feedback?askLogId={{askLogId}}&pageNo=1&pageSize=10
Authorization: Bearer {{authToken}}

### Evaluation Summary
GET {{baseUrl}}/api/v1/ai/evaluation/summary?recentLimit=5
Authorization: Bearer {{authToken}}

### Inspect Latest Ask Logs in Database
# Run this SQL in DBeaver after Ask AI:
# SELECT id, question, retrieval_keyword, prompt_tokens, completion_tokens, total_tokens, retrieved_chunk_ids, elapsed_ms, status, created_at
# FROM devmind.ai_ask_log
# ORDER BY id DESC;

### Inspect Bad Case Feedback in Database
# Run this SQL in DBeaver after Submit AI Ask Feedback:
# SELECT id, ask_log_id, helpful, reason, expected_answer, created_at
# FROM devmind.ai_ask_feedback
# ORDER BY id DESC;

### Update Document
PUT {{baseUrl}}/api/v1/documents/{{documentId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Redis cache penetration review updated",
  "content": "Updated problem:\nRepeated requests for non-existing data can bypass Redis and pressure MySQL.\n\nUpdated solution:\nCache empty values, validate parameters, add rate limiting, and monitor abnormal miss rates.\n\nRAG note:\nAfter this update, old chunks should be archived and new chunks should be generated.",
  "sourceType": "bug_review",
  "tags": "redis,cache,backend,rag",
  "summary": "Updated cache penetration note."
}

### Archive Document
DELETE {{baseUrl}}/api/v1/documents/{{documentId}}
Authorization: Bearer {{authToken}}

### Logout
# Run this one at the end. After logout, this token is written to the Redis blacklist.
POST {{baseUrl}}/api/v1/auth/logout
Authorization: Bearer {{authToken}}
